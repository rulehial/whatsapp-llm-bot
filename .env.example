# El bot usa el Vercel AI SDK, que detecta el proveedor de IA automáticamente
# a partir de PROVIDER (ver abajo) y busca la API key de ese proveedor por el
# nombre exacto de su variable de entorno — no hace falta pasarla a mano en
# ningún lado del código.

# Proveedor activo. Debe coincidir con un paquete @ai-sdk/<PROVIDER> instalado
# (ya vienen instalados @ai-sdk/groq y @ai-sdk/anthropic; para usar otro,
# instala su paquete, ej. "npm install @ai-sdk/openai").
PROVIDER=groq

# Modelo a pedirle al proveedor activo. Su formato depende del proveedor:
# con Groq, ej. "llama-3.3-70b-versatile"; con Anthropic, ej. "claude-opus-4-8".
MODEL=llama-3.3-70b-versatile

# Clave del proveedor activo (Groq). Consíguela gratis, sin tarjeta de
# crédito, en https://console.groq.com/
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Alternativa: para usar Anthropic (Claude) en vez de Groq, cambia
# PROVIDER=anthropic y MODEL a un ID de Anthropic arriba, y descomenta esta
# clave. Consíguela en https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
